generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     User[]
  clients   Client[]
  sites     Site[]
  pageInventory SitePageInventory[]
  findings  Finding[]
  alerts    Alert[]
}

model Client {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  contactPerson String?
  email         String?
  phone         String?
  notes         String?
  isArchived    Boolean  @default(false)
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sites         Site[]
}

model Site {
  id             String          @id @default(cuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  siteName       String
  siteUrl        String          @unique
  apiKeyHash     String
  status         String          @default("unknown")
  lastSeenAt     DateTime?
  agentSyncIntervalHours Int     @default(12)
  pageCheckIntervalHours Int     @default(12)
  lastPageCheckAt DateTime?
  nextPageCheckAt DateTime?
  isArchived     Boolean         @default(false)
  archivedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  snapshots      SiteSnapshot[]
  plugins        SitePlugin[]
  monitoredPages MonitoredPage[]
  pageInventory  SitePageInventory[]
  findings       Finding[]
  alerts         Alert[]
}

model SiteSnapshot {
  id                  String   @id @default(cuid())
  siteId              String
  site                Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  wordpressVersion    String?
  phpVersion          String?
  mysqlVersion        String?
  activeThemeName     String?
  activeThemeVersion  String?
  coreUpdateAvailable Boolean  @default(false)
  pluginUpdatesCount  Int      @default(0)
  themeUpdateAvailable Boolean @default(false)
  debugMode           Boolean  @default(false)
  fileEditorEnabled   Boolean  @default(false)
  createdAt           DateTime @default(now())
}

model SitePlugin {
  id              String   @id @default(cuid())
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  version         String?
  latestVersion   String?
  status          String
  updateAvailable Boolean  @default(false)
  lastSeenAt      DateTime @default(now())
}

model MonitoredPage {
  id        String      @id @default(cuid())
  siteId    String
  site      Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  label     String
  url       String
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  checks    PageCheck[]
}

model PageCheck {
  id              String        @id @default(cuid())
  monitoredPageId String
  monitoredPage   MonitoredPage @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)
  httpStatus      Int?
  responseTimeMs  Int?
  errorDetected   Boolean       @default(false)
  errorSummary    String?
  checkedAt       DateTime      @default(now())
}

model SitePageInventory {
  id                   String   @id @default(cuid())
  tenantId             String
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId               String
  site                 Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title                String
  url                  String
  postType             String?
  status               String?
  modifiedAt           DateTime?
  importance           String   @default("normal")
  recommendationReason String?
  isMonitored          Boolean  @default(false)
  firstSeenAt          DateTime @default(now())
  lastSeenAt           DateTime @default(now())
  isActive             Boolean  @default(true)
  fingerprint          String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([siteId, fingerprint])
}

model Finding {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId          String
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  source          String
  severity        String
  title           String
  description     String?
  recommendation  String?
  fingerprint     String
  status          String    @default("open")
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  resolvedAt      DateTime?
  occurrenceCount Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, fingerprint])
}

model Alert {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId          String
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  findingId       String?
  source          String
  severity        String
  title           String
  message         String?
  recommendation  String?
  fingerprint     String
  status          String    @default("open")
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  resolvedAt      DateTime?
  acknowledgedAt  DateTime?
  acknowledgedBy  String?
  snoozedUntil    DateTime?
  occurrenceCount Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, fingerprint])
}
